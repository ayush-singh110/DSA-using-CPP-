class Solution {
public:
    int longestConsecutive(vector<int>& nums) {
        if (nums.size()==0){
            return 0;
        }
        unordered_set <int> s(nums.begin(),nums.end());
        int longest=1;
        for (auto it:s){
            if (s.find(it-1)==s.end()){
                int x=it;
                int cnt=1;
                while (s.find(x+1)!=s.end()){
                    x=x+1;
                    cnt=cnt+1;
                }
                longest=max(cnt,longest);
            }
        }
        return longest;
    }
};
