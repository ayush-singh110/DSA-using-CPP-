class Solution {
private:
    string c(int n){
        if (n==0){
            return "0";
        }
        string a="";
        while (n!=0){
            a=a+to_string(n%2);
            n=n/2;
        }
        reverse(a.begin(),a.end());
        return a;
    }
    int co(string j){
        int h=0;
        int l=0;
        for (int i=j.size()-1;i>=0;i--){
            if (j[i]=='1'){
                h=h+pow(2,l);
            }
            else if (j[i]=='0'){
                h=h+0;
            }
            l++;
        }
        return h;
    }
public:
    int bitwiseComplement(int n) {
        string s=c(n);
        for (int i=0;i<s.size();i++){
            if (s[i]=='0'){
                s[i]='1';
            }
            else if (s[i]=='1'){
                s[i]='0';
            }
        }
        for (auto it:s){
            cout<<it<<" ";
        }
        int a=co(s);
        return a;
    }
};
