class Solution {
public:
    int widthOfBinaryTree(TreeNode* root) {
        queue <pair<TreeNode*,long long>> q;
        q.push({root,0});
        int m=INT_MIN;
        while (!q.empty()){
            int size=q.size();
            int min_ind=q.front().second;
            int first,end;
            for (int i=0;i<size;i++){
                root=q.front().first;
                long long curid=q.front().second-min_ind;
                q.pop();
                if (i==0){
                    first=curid;
                }
                if (i==size-1){
                    end=curid;
                }
                if (root->left!=NULL){
                    q.push({root->left,2*curid+1});
                }
                if (root->right!=NULL){
                    q.push({root->right,2*curid+2});
                }
            }
            m=max(m,end-first+1);
        }
        return m;
    }
};
