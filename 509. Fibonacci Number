class Solution {
    int generate(int n,vector <int> &dp){
        if (n==0){
            return 0;
        }
        if (n==1){
            return 1;
        }
        if (dp[n]!=-1){
            return dp[n];
        }
        dp[n]=generate(n-1,dp)+generate(n-2,dp);
        return dp[n];
    }
public:
    int fib(int n) {
        if (n==1){
            return 1;
        }
        if (n==0){
            return 0;
        }
        vector <int> dp(n+1,-1);
        dp[0]=0;
        dp[1]=1;
        int result=generate(n,dp);
        return result;
    }
};
