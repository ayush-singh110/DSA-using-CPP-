class Solution {
public:
    vector<vector<int>> generate(int numRows) {
        if (numRows==1){
            return {{1}};
        }
        vector <vector <int>> result;
        result.push_back({1});
        result.push_back({1,1});
        for (int i=2;i<numRows;i++){
            vector <int> prev=result[i-1];
            vector <int> next(i+1,0);
            for (int j=0;j<=i;j++){
                if (j==0){
                    next[j]=1;
                }
                else if (j==i){
                    next[j]=1;
                }
                else {
                    next[j]=prev[j-1]+prev[j];
                }
            }
            result.push_back(next);
        }
        return result;
        }
};
