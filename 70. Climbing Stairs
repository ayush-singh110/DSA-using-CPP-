class Solution {
private:
    int climb(int n,vector <int> &dp){
        if (n==1){
            return 1;
        }
        if (n==2){
            return 2;
        }
        if (dp[n]!=-1){
            return dp[n];
        }
        dp[n]=climb(n-1,dp)+climb(n-2,dp);
        return dp[n];
    }
public:
    int climbStairs(int n) {
        vector <int> dp(n+1,-1);
        dp[0]=1;
        dp[1]=1;
        int ans=climb(n,dp);
        return ans;
    }
};
