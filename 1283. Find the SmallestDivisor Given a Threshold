class Solution {
    long long div(vector <int> &nums,int mid){
        long long sum=0;
        for (int i=0;i<nums.size();i++){
            sum=sum+ceil((double)nums[i]/(double)mid);
        }
        return sum;
    }
public:
    int smallestDivisor(vector<int>& nums, int threshold) {
        int maxi=INT_MIN;
        for (int i=0;i<nums.size();i++){
            maxi=max(maxi,nums[i]);
        }
        int start=1;
        int end=maxi;
        int result=maxi;
        while (start<=end){
            int mid=start+(end-start)/2;
            long long divi=div(nums,mid);
            if (divi<=threshold){
                result=mid;
                end=mid-1;
            }
            else{
                start=mid+1;
            }
        }
        return result;
    }
};
