class Solution {
public:
    string processStr(string s) {
        string result="";
        for (int i=0;i<s.size();i++){
            if (s[i]=='*'){
                if (!(result.empty())){
                    result.erase(result.begin()+result.size()-1);
                }
                else{
                    continue;
                }
            }
            else if (s[i]=='#'){
                if (!(result.empty())){
                    string a=result;
                    result=result+a;
                }
                else{
                    continue;
                }
            }
            else if (s[i]=='%'){
                if (!(result.empty())){
                    reverse(result.begin(),result.end());
                }
                else{
                    continue;
                }
            }
            else{
                result=result+s[i];
            }

        }
        return result;
    }
};
