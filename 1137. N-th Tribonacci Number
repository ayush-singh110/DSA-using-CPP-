class Solution {
    int tribo(int n,vector <int> &dp){
        if (n==0){
            return 0;
        }
        if (n==1){
            return 1;
        }
        if (n==2){
            return 1;
        }
        if (dp[n]!=-1){
            return dp[n];
        }
        dp[n]=tribo(n-1,dp)+tribo(n-2,dp)+tribo(n-3,dp);
        return tribo(n-1,dp)+tribo(n-2,dp)+tribo(n-3,dp);
    }
public:
    int tribonacci(int n) {
        if (n==0){
            return 0;
        }
        if (n==1 || n==2){
            return 1;
        }
        vector <int> dp(n+1,-1);
        dp[0]=0;
        dp[1]=1;
        dp[2]=1;
        int result=tribo(n,dp);
        return result;
    }
};
